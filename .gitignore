Thumbs.db

# ═══════════════════════════════════════════════════════════
# EVM Runtime Artifacts
# ═══════════════════════════════════════════════════════════
# Storage file + lock (created by EnvironmentManager)
*.lock
# Operation history (JSONL)
*.jsonl
# Backup files (backup_YYYYMMDD_HHMMSS.json)
backup_*.json
# .env import files (test artifacts)
*.env
# Default storage directory
.evm/

# ═══════════════════════════════════════════════════════════
# JSON Files (exclude by default, allowlist below)
# ═══════════════════════════════════════════════════════════
# Catch-all for stray JSON (test outputs, temp data, etc.)
# Use negation to track legitimate JSON assets.
*.json
# Skill eval fixtures
!skill/evals/*.json

# ═══════════════════════════════════════════════════════════
# Tool / Agent Config
# ═══════════════════════════════════════════════════════════
